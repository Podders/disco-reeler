{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vinyl Reel Recorder",
  "version": "0.1.3",
  "identifier": "com.stevepodmore.vinylreelrecorder",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vinyl Reel Recorder",
        "width": 1440,
        "height": 960,
        "titleBarStyle": "Transparent",
        "backgroundColor": "#04070c"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "externalBin": ["binaries/ffmpeg"],
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
